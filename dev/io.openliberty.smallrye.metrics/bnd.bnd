-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

Bundle-Name: io.openliberty.smallrye.metrics
Bundle-SymbolicName: io.openliberty.smallrye.metrics
Bundle-Description: MicroProfile Metrics SmallRye Implementation, version ${bVersion}

Import-Package: \
	javax.enterprise.*;version="[1.1,3)",\
	javax.inject;version='[1.0,2.1)',\
	*

Include-Resource: \
    META-INF=resources/META-INF
    
Export-Package: \
    io.smallrye.metrics.*;version=3.0.0

WS-TraceGroup: METRICS

-cdiannotations:

-dsannotations-inherit: true
-dsannotations: \
	io.smallrye.metrics.setup.MetricCdiInjectionExtension

-buildpath: \
	com.ibm.websphere.javaee.cdi.2.0;version=latest,\
	com.ibm.websphere.javaee.interceptor.1.2;version=latest,\
	com.ibm.ws.org.osgi.annotation.versioning;version=latest,\
	io.openliberty.org.eclipse.microprofile.config.2.0;version=latest,\
	io.openliberty.org.eclipse.microprofile.metrics.3.0;version=latest,\
	com.ibm.ws.org.jboss.logging;version=latest,\
	javax.json-api;version=latest,\
	com.ibm.websphere.javaee.servlet.3.1;version=latest,\
	com.ibm.websphere.javaee.annotation.1.2;version=latest,\
	javax.ws.rs-api;version=latest,\
	com.ibm.ws.org.glassfish.json.1.1;version=latest,\
	com.ibm.ws.adaptable.module;version=latest,\
	com.ibm.websphere.javaee.cdi.2.0;version=latest,\
	com.ibm.wsspi.org.osgi.service.component.annotations;version=latest,\
	com.ibm.wsspi.org.osgi.service.component;version=latest,\
	com.ibm.ws.cdi.interfaces;version=latest,\
	com.ibm.ws.container.service;version=latest,\
	com.ibm.ws.container.service.compat;version=latest,\
	com.ibm.ws.classloading;version=latest,\
	com.ibm.ws.kernel.service;version=latest,\
	com.ibm.websphere.org.osgi.core;version=latest,\
    com.ibm.websphere.javaee.concurrent.1.0;version=latest,\
    com.ibm.ws.logging;version=latest,\
    org.jboss.logging:jboss-logging-annotations;version=2.2.1.Final,\
    org.jboss.logging:jboss-logging-processor;version=2.2.1.Final,\
    com.ibm.ws.org.jboss.logging;version=latest,\
    io.micrometer:micrometer-core;version=1.5.5,\
    io.micrometer:micrometer-registry-prometheus;version=1.5.5

